{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "jsx": "react",
    "typeRoots": ["./src/@types", "./node_modules/@types"]
  },
    "include": ["src/**/*.ts", "src/**/*.tsx"]
}
